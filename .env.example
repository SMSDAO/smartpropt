# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_ID_FREE=price_xxx_free_tier
STRIPE_PRICE_ID_PRO=price_xxx_pro_tier
STRIPE_PRICE_ID_LIFETIME=price_xxx_lifetime_tier
STRIPE_PRICE_ID_ENTERPRISE=price_xxx_enterprise_tier

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Farcaster Configuration (Optional)
FARCASTER_API_KEY=your_farcaster_api_key
FARCASTER_APP_FID=your_farcaster_app_fid

# NFT Mint Configuration (Base Network)
NFT_CONTRACT_ADDRESS=your_nft_contract_address
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=your_nft_contract_address
NFT_DEPLOYER_PRIVATE_KEY=your_deployer_private_key
BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
BASESCAN_API_KEY=your_basescan_api_key_here

# Admin Configuration
ADMIN_EMAIL=admin@yourdomain.com

# Production/Preview Environment
NODE_ENV=development

# Upstash Redis (Production Rate Limiting)
# Get from https://console.upstash.com — required for distributed rate limiting on Vercel
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# WalletConnect (required for RainbowKit wallet connections)
# Get your Project ID from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

